# ZeroTrustGuard — Backend Environment Variables
# Copy this file to .env and fill in your values
# Generate a JWT secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Frontend URL (used by CORS) ───────────────────────────────────────────────
FRONTEND_URL=http://localhost:8081
# Production example:
# FRONTEND_URL=https://your-vercel-app.vercel.app

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: Local PostgreSQL (individual vars)
DB_NAME=zerotrust
DB_USER=postgres
DB_PASS=YOUR_POSTGRES_PASSWORD_HERE
DB_HOST=localhost

# Option B: Supabase / Render (connection string — takes priority over individual vars)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_this_with_a_secure_random_string_min_32_chars

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Development: use Mailtrap (https://mailtrap.io → Email Testing → SMTP Settings)
# Production:  use Gmail App Password or SendGrid
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM="ZeroTrustGuard <no-reply@zerotrustguard.com>"
